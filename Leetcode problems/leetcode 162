// Approach 1 (Brute Force):
// Traverse the array using a simple for loop.
// Check if nums[i] is greater than both its neighbours.
// i.e., nums[i-1] < nums[i] && nums[i] > nums[i+1].
// Return the index of the first peak found.
// Time Complexity: O(n)
// Space Complexity: O(1)


// Approach 2 (Binary Search - Optimal):
// 1. If the array has only one element, return index 0.
// 2. If the first element is greater than the second, return index 0.
//    (The element before index 0 is considered -∞.)
// 3. If the last element is greater than the second last, return index n-1.
//    (The element after the last index is considered -∞.)
// 4. Apply binary search on indices [1, n-2].
// 5. If nums[mid] is greater than both neighbours, it is the peak.
// 6. If nums[mid] > nums[mid+1], we are on the descending slope,
//    so a peak lies on the left. Move h = mid - 1.
// 7. Otherwise, we are on the ascending slope,
//    so a peak lies on the right. Move l = mid + 1.

// Time Complexity: O(log n)
// Space Complexity: O(1)


class Solution {
public:
    int findPeakElement(vector<int>& nums) {
        int n=nums.size();
        int l=1;
        int h=n-2;

        if(n==1) return 0;
        if(nums[0]>nums[1]) return 0;
        if(nums[n-1]>nums[n-2]) return n-1;

        int mid=l+(h-l)/2;
        while(l<=h){
            int mid=l+(h-l)/2;
            if(nums[mid-1]<nums[mid] && nums[mid]>nums[mid+1]){
                return mid;
            }
            else if(nums[mid]>nums[mid+1]){
                h=mid-1;
            }
            else {
                l=mid+1;
            }
        }
        return -1;
    }
};
