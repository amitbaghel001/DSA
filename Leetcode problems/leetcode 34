// Approach: we will use 2 binary searches one for finding the 1st occurence and the 2nd for the last occurence , make 2 functions and follow the approach if the mid element is = to the target then for finding 1st occurence we have to make search h=mid-1;
// for last occurence we will make l=h+1 and then return these two index to our final function

class Solution {
private:
int firstoccurence(vector<int>& nums, int target){
    int n=nums.size();
    int l=0;
    int h=n-1;
    int ans1=-1;
        while(l<=h){
            int mid=l+(h-l)/2;
            if(nums[mid]==target){
                ans1=mid;
                h=mid-1;
            }
            else if(nums[mid]>target){
                h=mid-1;
            }
            else{
                l=mid+1;
            }
        }
    return ans1;  
}

int lastocuurence(vector<int>& nums, int target){
    int n=nums.size();
    int l=0;
    int h=n-1;
    int ans2=-1;
        while(l<=h){
            int mid=l+(h-l)/2;
            if(nums[mid]==target){
                ans2=mid;
                l=mid+1;
            }
            else if(nums[mid]>target){
                h=mid-1;
            }
            else{
                l=mid+1;
            }
        }
    return ans2;  
}

public:
    vector<int> searchRange(vector<int>& nums, int target) {
        
    return {firstoccurence(nums,target),lastocuurence( nums, target)};
    }
};
