//brute force//

class Solution {
public:
    bool isPowerOfTwo(int n) {
        if(n <= 0) return false;

        for(int x = 0; x <= log2(n); x++){
            if((double)n == pow(2, x))
                return true;
        }

        return false;
    }
};

