
// Approach:
// Dekho 1st of all dono ke last bit se start krte hn and right se left ayenge ,ek variable bnake jisme hum sum store karein and ek me carry and ek final string ans return krane ke liye , fir ans me carry then 1st string ka then 2nd string ko add kro , and finally ans me add krdo with % ,, like sum=3 then ans me will will take it as 1 and 1 will be carry , carry =sum/2; 

class Solution {
public:
    string addBinary(string a, string b) {

    int i = a.length() - 1;
    int j = b.length() - 1;
    int carry = 0;
    string ans = "";

    while( i>=0 || j>=0 ||carry){
        int sum=carry;
        
        if(i>=0){
            int x=a[i]-'0';
            sum+=x;
            i--;
        }
        if(j>=0){
            int y=b[j]-'0';
            sum+=y;
            j--;
        }

        ans+=(sum % 2)+'0';
        carry=sum/2;
    }
    reverse(ans.begin(),ans.end());
    return ans;
    }
};
